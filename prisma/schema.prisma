generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String           @id @default(cuid())
  clerkId        String           @unique
  assets          Asset[]
  transactions    Transaction[]
  fixedIncomeLots FixedIncomeLot[]
  dividends       Dividend[]
}

model Transaction {
  id        String   @id @default(cuid())
  ticker    String
  type      String   // "stock_br" | "crypto" | "stock_us"
  operation String   // "BUY" | "SELL"
  quantity  Float
  price     Float
  date      DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Asset {
  id            String    @id @default(cuid())
  ticker        String
  type          String    // "stock_br" | "fii" | "crypto" | "stock_us"
  quantity      Float
  avgPrice      Float
  cachedPrice   Float?
  cachedPriceAt DateTime?
  assetSubType  String?   // e.g., "tijolo", "papel", "híbrido" para FIIs; "banco", "energia" para ações
  sector        String?   // ramo/setor do ativo
  notes         String?   // observações livres
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  createdAt     DateTime  @default(now())
}

model Dividend {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  ticker    String
  type      String   // "stock_br" | "fii"
  amount    Float    // valor recebido em R$
  paidAt    DateTime // data do pagamento
  createdAt DateTime @default(now())
}

model FixedIncomeLot {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  name          String
  subType       String   // "tesouro" | "cdb"
  investedValue Float
  currentValue  Float?   // atualizado manualmente pelo usuário via app do banco
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
